# String de conexão completa do Neon PostgreSQL
# Substitua pelos seus dados reais no arquivo .env (não commitar)
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/nomedb?sslmode=require"

# Chave da API Correios RapidAPI (https://rapidapi.com/carlosgdelgado/api/correios-rastreamento-de-encomendas)
# Deixe vazio ou como "minha_key_aqui" para usar dados mockados
RAPIDAPI_KEY=minha_key_aqui
RAPIDAPI_HOST=correios-rastreamento-de-encomendas.p.rapidapi.com
RAPIDAPI_BASE_URL=https://correios-rastreamento-de-encomendas.p.rapidapi.com
